msgstr "Bricks-Daten in Suchergebnissen abfragen"

#: ../includes/admin/admin-screen-settings.php:448,
#: ../includes/elements/image.php:399
msgid "Theme styles"
msgstr "Theme-Stile"

#: ../includes/admin/admin-screen-settings.php:448
