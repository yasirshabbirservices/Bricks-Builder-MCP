#: ../includes/admin/admin-screen-settings.php:2013,
#: ../includes/admin/admin-screen-settings.php:2949
msgid "Last generated"
msgstr "Pēdējoreiz ģenerēts"

#: ../includes/admin/admin-screen-settings.php:2018
