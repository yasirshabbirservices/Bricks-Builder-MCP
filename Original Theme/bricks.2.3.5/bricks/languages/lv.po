msgstr "Iestatiet, ja jums ir problēmas ar Bricks iebūvēto slinko ielādi."

#: ../includes/admin/admin-screen-settings.php:1925
msgid "Lazy load offset"
msgstr "Slinkās ielādes nobīde"

#: ../includes/admin/admin-screen-settings.php:1932,
#: ../includes/admin/admin-screen-settings.php:1936
msgid "Disable jQuery migrate"
msgstr "Atspējot jQuery migrate"

#: ../includes/admin/admin-screen-settings.php:1937
