msgstr "Mở rộng phần tử đang hoạt động & cuộn vào tầm nhìn"

#: ../includes/admin/admin-screen-settings.php:1677
msgid "Wrap element"
msgstr "Bọc phần tử"

#: ../includes/admin/admin-screen-settings.php:1685
